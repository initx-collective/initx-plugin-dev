  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@initx-plugin/core": "^0.4.0",
    "@initx-plugin/utils": "^0.4.0",
    "@types/node": "^25.9.2",
    "bumpp": "^11.1.0",
    "eslint": "^10.4.1",
    "nano-staged": "^1.0.2",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^6.0.3",
    "unbuild": "^3.6.1"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm nano-staged"
